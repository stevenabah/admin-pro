generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  nickname  String?
  email     String?
  phone     String?
  avatar    String?
  status    Int      @default(1)
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 分配给我的任务
  assignedTasks  Task[]  @relation("TaskAssignee")
  // 我创建的任务
  createdTasks   Task[]  @relation("TaskCreator")
  // 任务日志
  taskLogs       TaskLog[] @relation("TaskLogUser")
  // 评论
  comments       Comment[] @relation("CommentUser")
  // 我关注的任务
  watchedTasks   TaskWatch[] @relation("TaskWatchUser")
}

model Role {
  id          String        @id @default(uuid())
  name        String
  code        String        @unique
  description String?
  status      Int           @default(1)
  permissions Permission[]
  users       User[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Permission {
  id          String       @id @default(uuid())
  name        String
  code        String       @unique
  type        String       @default("menu")
  path        String?
  icon        String?
  component   String?
  sort        Int          @default(0)
  parentId    String?
  parent      Permission?  @relation("PermissionToPermission", fields: [parentId], references: [id], onDelete: SetNull)
  children    Permission[] @relation("PermissionToPermission")
  roles       Role[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model File {
  id          String   @id @default(uuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  path        String
  url         String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  title     String
  type      String
  url       String
  duration  Int?
  cover     String?
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DataRecord {
  id        String   @id @default(uuid())
  title     String
  content   String?
  category  String?
  amount    Float?
  status    Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 任务表 (状态和优先级使用字符串，枚举值在应用层校验)
// status: PENDING | IN_PROGRESS | REVIEW | COMPLETED | CANCELLED
// priority: LOW | MEDIUM | HIGH | URGENT
model Task {
  id             String   @id @default(uuid())
  title          String
  description    String?
  status         String   @default("PENDING")
  priority       String   @default("MEDIUM")
  assigneeId     String?
  creatorId      String
  dueDate        DateTime?
  tags           String?  // JSON数组，存储标签ID列表，如 ["tag1", "tag2"]
  parentId       String?  // 父任务ID，支持子任务
  recurrenceRule String?  // Cron表达式，用于重复任务，如 "0 0 * * *" 表示每天凌晨
  isRecurrence   Boolean  @default(false) // 是否为重复任务产生的实例
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  assignee       User?     @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator        User      @relation("TaskCreator", fields: [creatorId], references: [id])
  parent         Task?     @relation("TaskParent", fields: [parentId], references: [id], onDelete: Cascade)
  children       Task[]    @relation("TaskParent")
  logs           TaskLog[]
  comments       Comment[]
  watchers       TaskWatch[]

  @@index([status])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([dueDate])
  @@index([parentId])
}

// 标签表
model Tag {
  id        String   @id @default(uuid())
  name      String
  color     String   @default("#409eff") // 标签颜色
  userId    String?  // 创建者ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// 任务日志表
model TaskLog {
  id            String   @id @default(uuid())
  taskId        String
  userId        String
  action        String   // 动作类型: create, update, status_change, assign, comment, watch, unwatch, subtask_create
  beforeStatus  String?
  afterStatus   String?
  content       String?  // 额外描述
  ipAddress     String?  // 操作者IP地址
  userAgent     String?  // 操作者User Agent
  changeDetails String?  // JSON格式，记录变更详情
  createdAt     DateTime @default(now())

  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User     @relation("TaskLogUser", fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

// 评论表
model Comment {
  id            String   @id @default(uuid())
  taskId        String
  userId        String
  content       String
  mentions      String?  // JSON数组，存储被@的用户ID列表，如 ["userId1", "userId2"]
  attachments   String?  // JSON数组，存储附件ID列表，如 ["fileId1", "fileId2"]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  task          Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user          User     @relation("CommentUser", fields: [userId], references: [id])

  @@index([taskId])
  @@index([userId])
}

// 任务关注表 (用于收藏/关注任务)
model TaskWatch {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  createdAt DateTime @default(now())

  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("TaskWatchUser", fields: [userId], references: [id])

  @@unique([taskId, userId])
  @@index([taskId])
  @@index([userId])
}

// 通知表
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // 通知类型: mention(提及), assign(分配), status_change(状态变更), comment(评论), overdue(逾期)
  title     String
  content   String?
  taskId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([taskId])
}