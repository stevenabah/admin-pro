# ============================================
# Production Environment Variables
# ============================================

# Application
NODE_ENV=production
PORT=3000

# Database - PostgreSQL
DATABASE_URL=postgresql://admin_pro:CHANGE_ME@postgres:5432/admin_pro?schema=public

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# JWT Authentication
JWT_SECRET=CHANGE_ME_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARS
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=https://admin-pro.com

# File Upload
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=10485760

# SSL (for production)
SSL_ENABLED=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
